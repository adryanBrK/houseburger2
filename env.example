# Configurações de segurança
SECRET_KEY=troque-esta-chave-em-producao-por-uma-chave-secreta-forte
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Banco de dados
# Para desenvolvimento local (SQLite):
# DATABASE_URL=sqlite:///./banco.db

# Para produção na Vercel (PostgreSQL):
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco
# Exemplo com Neon, Supabase ou Railway:
# DATABASE_URL=postgresql://user:password@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb
